---
/* ==========================================================================
   BASE LAYOUT — Estructura HTML comun de todas las paginas
   Incluye <head> con SEO (meta, Open Graph, Twitter y datos estructurados
   JSON-LD), carga de fuentes, header, footer y boton flotante de WhatsApp.
   ========================================================================== */

import { site, telHref } from '../config/site';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BotonWhatsApp from '../components/BotonWhatsApp.astro';
import Preloader from '../components/Preloader.astro';

// Tipografias empaquetadas con Fontsource (sin CDN de Google).
// Titulos: Bebas Neue (un solo peso). Cuerpo: Montserrat (varios pesos).
import '@fontsource/bebas-neue/400.css';
import '@fontsource/montserrat/400.css';
import '@fontsource/montserrat/500.css';
import '@fontsource/montserrat/600.css';
import '@fontsource/montserrat/700.css';

// Estilos globales + tokens de marca.
import '../styles/global.css';

interface Props {
  /** Titulo de la pestana (se le anade el nombre de la empresa) */
  titulo: string;
  /** Meta descripcion para buscadores (opcional, usa la global por defecto) */
  descripcion?: string;
  /** Palabras clave especificas de la pagina (se suman a las globales) */
  palabrasClave?: string[];
  /** Imagen para compartir en redes (ruta absoluta o relativa a la raiz) */
  imagen?: string;
  /** Esquemas JSON-LD adicionales de la pagina (se anaden al @graph global) */
  esquemas?: Record<string, unknown>[];
}

const {
  titulo,
  descripcion = site.descripcion,
  palabrasClave = [],
  imagen = '/og-image.png',
  esquemas = [],
} = Astro.props;

const tituloCompleto = `${titulo} | ${site.nombreCorto}`;
// URL canonica absoluta de la pagina actual.
const canonical = new URL(Astro.url.pathname, site.url).href;
const imagenAbs = new URL(imagen, site.url).href;
const keywords = [...palabrasClave, ...site.palabrasClave].join(', ');

// Datos estructurados (Schema.org) como @graph: empresa local + sitio web +
// migas de pan (breadcrumbs) por ruta + cualquier esquema propio de la pagina.
const orgId = `${site.url}/#empresa`;
const webId = `${site.url}/#website`;

// Redes sociales no vacias -> sameAs (mejora el reconocimiento de la marca).
const sameAs = Object.values(site.redes).filter(Boolean);

const empresa = {
  '@type': 'LocalBusiness',
  '@id': orgId,
  name: site.nombre,
  alternateName: site.nombreCorto,
  url: site.url,
  description: site.descripcion,
  slogan: site.eslogan,
  email: site.email,
  telephone: site.telefonos.map((t) => telHref(t)),
  image: imagenAbs,
  logo: new URL('/og-image.png', site.url).href,
  foundingDate: site.empresa.anioFundacion,
  taxID: site.empresa.ruc,
  vatID: site.empresa.ruc,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.empresa.direccionLegal,
    addressLocality: 'Arequipa',
    addressRegion: 'Arequipa',
    addressCountry: 'PE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.empresa.lat,
    longitude: site.empresa.lng,
  },
  areaServed: site.sectores,
  // Atencion 24/7 (coincide con el horario publicado en el sitio).
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  },
  ...(sameAs.length ? { sameAs } : {}),
};

const webSite = {
  '@type': 'WebSite',
  '@id': webId,
  url: site.url,
  name: site.nombre,
  inLanguage: 'es-PE',
  publisher: { '@id': orgId },
};

// Migas de pan a partir de la ruta actual (usa las etiquetas del menu).
const segmentos = Astro.url.pathname.split('/').filter(Boolean);
const migas = [{ name: 'Inicio', url: `${site.url}/` }];
let ruta = '';
for (const seg of segmentos) {
  ruta += `/${seg}`;
  const enlace = site.nav.find((n) => n.href === `${ruta}/`);
  migas.push({ name: enlace?.texto ?? seg, url: new URL(`${ruta}/`, site.url).href });
}
const breadcrumb =
  migas.length > 1
    ? [
        {
          '@type': 'BreadcrumbList',
          itemListElement: migas.map((m, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            name: m.name,
            item: m.url,
          })),
        },
      ]
    : [];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [empresa, webSite, ...breadcrumb, ...esquemas],
};
---

<!doctype html>
<html lang="es-PE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{tituloCompleto}</title>
    <meta name="description" content={descripcion} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={site.nombre} />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="PE-ARE" />
    <meta name="geo.placename" content="Arequipa" />

    {/* Open Graph (Facebook, WhatsApp, LinkedIn) */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content={site.nombre} />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imagenAbs} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={site.nombre} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tituloCompleto} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={imagenAbs} />
    <meta name="twitter:image:alt" content={site.nombre} />

    <meta name="generator" content={Astro.generator} />

    {/* Datos estructurados para SEO local */}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="flex min-h-screen flex-col">
    <Preloader />
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <BotonWhatsApp />

    {/* Animacion de aparicion al hacer scroll (revela elementos con data-reveal) */}
    <script>
      const elementos = document.querySelectorAll('[data-reveal]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        elementos.forEach((el) => el.classList.add('es-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('es-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        elementos.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
