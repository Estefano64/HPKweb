---
/* ==========================================================================
   PAGINA: NOSOTROS
   ========================================================================== */
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SedeCard from '../components/SedeCard.astro';
import HistoriaTaller from '../components/HistoriaTaller.astro';
import SomosComunidad from '../components/SomosComunidad.astro';
import nosotrosImg from '../assets/nosotros.jpg';
import { site } from '../config/site';

// Iconos por valor corporativo.
const iconosValor = [
  'mdi:shield-check-outline',
  'mdi:check-decagram-outline',
  'mdi:medal-outline',
  'mdi:clock-outline',
];
---

<BaseLayout titulo="Nosotros">
  {/* Cabecera de pagina */}
  <section class="border-b border-marca-borde bg-marca-niebla">
    <div class="contenedor py-16 md:py-20">
      <SectionHeading
        etiqueta="Nosotros"
        titulo="Trayectoria construida sobre calidad y confianza"
        descripcion="Conozca a la empresa detras del servicio."
      />
    </div>
  </section>

  {/* Historia + imagen */}
  <section class="seccion">
    <div class="contenedor grid items-center gap-12 md:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold">Sobre nosotros</h2>
        <p class="mt-5 leading-relaxed text-marca-secundario">
          Con más de quince años de experiencia, somos especialistas en ingeniería, diseño,
          mantenimiento, reparación y fabricación de partes para equipos móviles como camiones y
          flota auxiliar. Destacamos por nuestra contribución al exito de clientes en los sectores
          minero, construcción y pesquero, asegurando disponibilidad, confiabilidad y eficiencia
          técnica.
        </p>
        <p class="mt-4 leading-relaxed text-marca-secundario">
          Cumplimos con rigurosos estándares de seguridad industrial, salud ocupacional y
          protección ambiental, comprometidos siempre con estándares de calidad y servicios
          excepcionales.
        </p>
        <p class="mt-6 rounded-lg border-l-4 border-marca-acento bg-marca-niebla p-4 font-semibold text-marca-primario">
          Comprometidos las 24 horas, los 365 días del año, para ofrecer excelencia en nuestros
          servicios.
        </p>

        {/* Ficha de datos registrales */}
        <dl class="mt-8 grid grid-cols-1 gap-x-8 gap-y-3 border-t border-marca-borde pt-6 text-sm sm:grid-cols-2">
          <div>
            <dt class="font-semibold text-marca-tinta">RUC</dt>
            <dd class="text-marca-secundario">{site.empresa.ruc}</dd>
          </div>
          <div>
            <dt class="font-semibold text-marca-tinta">Tipo de empresa</dt>
            <dd class="text-marca-secundario">{site.empresa.tipo}</dd>
          </div>
          <div>
            <dt class="font-semibold text-marca-tinta">Inicio de actividades</dt>
            <dd class="text-marca-secundario">{site.empresa.inicioActividades}</dd>
          </div>
          <div>
            <dt class="font-semibold text-marca-tinta">Actividades</dt>
            <dd class="text-marca-secundario">{site.empresa.actividades.join('; ')}.</dd>
          </div>
        </dl>

        <h2 class="mt-10 flex items-center gap-3 text-2xl font-bold">
          <Icon name="mdi:target" class="h-7 w-7 text-marca-acento" />
          Nuestra misión
        </h2>
        <p class="mt-5 leading-relaxed text-marca-secundario">{site.mision}</p>

        <h2 class="mt-8 flex items-center gap-3 text-2xl font-bold">
          <Icon name="mdi:eye-outline" class="h-7 w-7 text-marca-acento" />
          Nuestra visión
        </h2>
        <p class="mt-5 leading-relaxed text-marca-secundario">{site.vision}</p>
      </div>

      <div>
        <Image
          src={nosotrosImg}
          alt="Equipo técnico de HP&K Inversiones frente al taller en Arequipa"
          class="w-full rounded-lg border border-marca-borde object-cover"
          width={1600}
          height={900}
        />
      </div>
    </div>
  </section>

  {/* Historia del taller */}
  <HistoriaTaller />

  {/* Valores */}
  <section class="seccion">
    <div class="contenedor">
      <SectionHeading
        etiqueta="Valores"
        titulo="Lo que guía nuestro trabajo"
        icono="mdi:compass-outline"
        centrado
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          site.valores.map((valor, i) => (
            <article
              class="group rounded-lg border border-marca-borde bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-marca-acento/40 hover:shadow-lg"
              data-reveal
              style={`--reveal-delay:${i * 90}ms`}
            >
              <span class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-marca-primario text-marca-resalte transition-colors group-hover:bg-marca-acento group-hover:text-white">
                <Icon name={iconosValor[i] ?? 'mdi:cog-outline'} class="h-6 w-6" />
              </span>
              <h3 class="text-lg font-bold">{valor.titulo}</h3>
              <p class="mt-2 text-sm leading-relaxed text-marca-secundario">{valor.resumen}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* Somos comunidad */}
  <SomosComunidad />

  {/* Sedes */}
  <section class="seccion">
    <div class="contenedor">
      <SectionHeading etiqueta="Presencia" titulo="Nuestra sede" icono="mdi:map-marker-outline" />
      <div class="mt-10 grid max-w-xl gap-6">
        {
          site.sedes.map((sede, i) => (
            <div data-reveal style={`--reveal-delay:${i * 100}ms`}>
              <SedeCard sede={sede} />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
