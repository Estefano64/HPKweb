---
/* ==========================================================================
   PAGINA: SERVICIOS
   Indice de tarjetas + detalle de cada servicio con el acabado del brochure:
   foto circular con arco turquesa y panel azul con titulo (palabra resaltada)
   y vinetas. El contenido sale del frontmatter de src/content/servicios/*.md.
   ========================================================================== */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServicioCard from '../components/ServicioCard.astro';
import IconoWA from '../components/IconoWA.astro';
import { site, waHref } from '../config/site';
import { imagenServicio } from '../lib/imagenes';

const servicios = (await getCollection('servicios'))
  .sort((a, b) => a.data.orden - b.data.orden)
  .map((s) => ({ ...s, imagen: imagenServicio(s.id) }));

// Datos estructurados: lista de servicios (Schema.org) para SEO.
const esquemaServicios = [
  {
    '@type': 'ItemList',
    name: `Servicios de ${site.nombreCorto}`,
    itemListElement: servicios.map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Service',
        name: s.data.titulo,
        description: s.data.resumen,
        url: `${site.url}/servicios/#${s.id}`,
        provider: { '@id': `${site.url}/#empresa` },
        areaServed: site.sectores,
        serviceType: s.data.titulo,
      },
    })),
  },
];

/** Divide el titulo en [antes, resaltado, despues] segun el fragmento "resalte". */
function dividirTitulo(titulo: string, resalte?: string): [string, string, string] {
  if (!resalte) return [titulo, '', ''];
  const i = titulo.toLowerCase().lastIndexOf(resalte.toLowerCase());
  if (i < 0) return [titulo, '', ''];
  return [titulo.slice(0, i), titulo.slice(i, i + resalte.length), titulo.slice(i + resalte.length)];
}
---

<BaseLayout
  titulo="Servicios"
  descripcion="Reparacion de cilindros hidraulicos, maquinado in situ, overhaul, mandos y frenos, diseno y reparacion estructural y fabricaciones en Arequipa, para los sectores minero, construccion y pesquero."
  palabrasClave={['reparacion de cilindros hidraulicos', 'maquinado in situ', 'overhaul de componentes', 'diseno estructural minero']}
  esquemas={esquemaServicios}
>
  <section class="border-b border-marca-borde bg-marca-niebla">
    <div class="contenedor py-16 md:py-20">
      <SectionHeading
        etiqueta="Servicios"
        titulo="Ingenieria, mantenimiento, reparacion y fabricacion"
        descripcion="Servicios orientados a la disponibilidad, confiabilidad y vida util de sus equipos, para los sectores minero, construccion y pesquero."
        icono="mdi:wrench-outline"
      />
    </div>
  </section>

  {/* Indice de servicios (tarjetas con foto) */}
  <section class="seccion">
    <div class="contenedor">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          servicios.map((servicio, i) => (
            <div data-reveal style={`--reveal-delay:${(i % 3) * 100}ms`}>
              <ServicioCard
                titulo={servicio.data.titulo}
                resumen={servicio.data.resumen}
                imagen={servicio.imagen}
                href={`#${servicio.id}`}
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Detalle de cada servicio (estilo brochure) */}
  {
    servicios.map((servicio, i) => {
      const [antes, resaltado, despues] = dividirTitulo(servicio.data.titulo, servicio.data.resalte);
      const invertido = i % 2 === 1;
      return (
        <section id={servicio.id} class:list={['seccion scroll-mt-20', invertido && 'bg-marca-niebla']}>
          <div class="contenedor grid items-center gap-10 md:grid-cols-2 lg:gap-16">
            {/* Foto circular con arco turquesa */}
            <div class:list={['flex justify-center', invertido && 'md:order-2']} data-reveal>
              <div class="relative aspect-square w-64 sm:w-72 lg:w-80">
                <div class="absolute -inset-2.5 -rotate-45 rounded-full border-[12px] border-marca-acento border-r-transparent border-t-transparent" aria-hidden="true" />
                <Image
                  src={servicio.imagen}
                  alt={`Servicio: ${servicio.data.titulo}`}
                  class="absolute inset-0 h-full w-full rounded-full border-4 border-white object-cover shadow-xl"
                  width={640}
                  height={640}
                  loading="lazy"
                />
              </div>
            </div>

            {/* Panel con titulo y vinetas */}
            <div class:list={[invertido && 'md:order-1']} data-reveal style="--reveal-delay:120ms">
              <div class="inline-block rounded-2xl rounded-tr-[2.25rem] bg-marca-primario px-6 py-4 shadow-sm md:px-8">
                <h2 class="text-2xl text-white md:text-3xl lg:text-4xl">
                  {antes}<span class="text-marca-acento">{resaltado}</span>{despues}
                </h2>
              </div>

              <ul class="mt-6 space-y-3">
                {servicio.data.items.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-marca-acento" aria-hidden="true" />
                    <span class="leading-relaxed text-marca-secundario">{item}</span>
                  </li>
                ))}
              </ul>

              {servicio.data.cierre && (
                <p class="mt-5 font-semibold text-marca-primario">{servicio.data.cierre}</p>
              )}

              <a
                href={waHref(`Hola ${site.nombreCorto}, quisiera cotizar el servicio: ${servicio.data.titulo}.`)}
                target="_blank"
                rel="noopener"
                class="btn-primario mt-6 whitespace-nowrap !bg-[#25D366] hover:!bg-[#1da851]"
              >
                <IconoWA size={18} />
                Cotizar este servicio
              </a>
            </div>
          </div>
        </section>
      );
    })
  }

  {/* Cierre */}
  <section class="bg-marca-primario">
    <div class="contenedor flex flex-col items-center gap-6 py-16 text-center">
      <h2 class="max-w-2xl text-3xl font-bold text-white">
        Cuentenos que equipo necesita atender
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contacto/" class="btn-primario bg-white !text-marca-primario hover:bg-marca-niebla">
          Contactar
        </a>
        <a href="/repuestos/" class="btn-secundario border-white/40 !text-white hover:bg-white/10">
          Ver repuestos
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
