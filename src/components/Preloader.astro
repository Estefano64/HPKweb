---
/* ==========================================================================
   PRELOADER — Pantalla de carga con pinones girando
   Se muestra al cargar y se oculta solo (evento load + tope de seguridad).
   Sin movimiento si el usuario prefiere menos animaciones.
   ========================================================================== */
import { Icon } from 'astro-icon/components';
import { site } from '../config/site';
---

<div id="preloader" class="preloader" role="status" aria-label="Cargando">
  <div class="relative h-28 w-28">
    <Icon name="mdi:cog" class="animar-giro absolute left-0 top-0 h-24 w-24 text-marca-acento" />
    <Icon name="mdi:cog" class="animar-giro-inverso absolute bottom-0 right-0 h-14 w-14 text-white" />
  </div>
  <p class="preloader__txt">{site.sigla} <span>Inversiones</span></p>
  <p class="preloader__sub">Cargando&hellip;</p>
</div>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    background: var(--color-marca-primario);
    transition:
      opacity 0.5s ease,
      visibility 0.5s ease;
  }
  .preloader--oculto {
    opacity: 0;
    visibility: hidden;
  }
  .preloader__txt {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.02em;
    color: #fff;
  }
  .preloader__txt span {
    color: var(--color-marca-resalte);
  }
  .preloader__sub {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }
</style>

<script is:inline>
  (function () {
    var hide = function () {
      var p = document.getElementById('preloader');
      if (!p) return;
      p.classList.add('preloader--oculto');
      setTimeout(function () {
        if (p && p.parentNode) p.parentNode.removeChild(p);
      }, 600);
    };
    if (document.readyState === 'complete') {
      hide();
    } else {
      window.addEventListener('load', hide);
    }
    // Tope de seguridad: nunca dejar la pantalla de carga bloqueada.
    setTimeout(hide, 3500);
  })();
</script>
