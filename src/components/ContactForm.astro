---
/* ==========================================================================
   CONTACT FORM — Formulario de contacto
   --------------------------------------------------------------------------
   Funciona SIN servidor: al enviar, abre el cliente de correo del visitante
   con un mensaje prellenado dirigido a ventas@hpkinv.com (mailto).

   COMO CONECTAR UN ENDPOINT REAL (opcional, para recibir sin abrir el correo
   del visitante):
   1. Crea una cuenta en un servicio de formularios (Formspree, Web3Forms, etc.)
      o usa un script PHP en cPanel.
   2. En la etiqueta del formulario (mas abajo):
        - quita el atributo id="form-contacto" y elimina el bloque de script final,
        - agrega: method="POST" action="https://TU-ENDPOINT"
   3. Listo: los campos name ya estan definidos para el envio.
   ========================================================================== */
import { site, waHref } from '../config/site';
import IconoWA from './IconoWA.astro';

// Numero de WhatsApp en formato wa.me (sin mensaje); el script le agrega el texto.
const waBase = waHref();
---

<form id="form-contacto" class="space-y-5" data-email={site.email} data-wa={waBase}>
  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="nombre" class="mb-1 block text-sm font-medium text-marca-tinta">Nombre completo</label>
      <input
        type="text"
        id="nombre"
        name="nombre"
        required
        class="w-full rounded-md border border-marca-borde px-4 py-2.5 focus:border-marca-acento focus:outline-none"
      />
    </div>
    <div>
      <label for="empresa" class="mb-1 block text-sm font-medium text-marca-tinta">Empresa</label>
      <input
        type="text"
        id="empresa"
        name="empresa"
        class="w-full rounded-md border border-marca-borde px-4 py-2.5 focus:border-marca-acento focus:outline-none"
      />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="correo" class="mb-1 block text-sm font-medium text-marca-tinta">Correo electronico</label>
      <input
        type="email"
        id="correo"
        name="correo"
        required
        class="w-full rounded-md border border-marca-borde px-4 py-2.5 focus:border-marca-acento focus:outline-none"
      />
    </div>
    <div>
      <label for="telefono" class="mb-1 block text-sm font-medium text-marca-tinta">Telefono</label>
      <input
        type="tel"
        id="telefono"
        name="telefono"
        class="w-full rounded-md border border-marca-borde px-4 py-2.5 focus:border-marca-acento focus:outline-none"
      />
    </div>
  </div>

  <div>
    <label for="mensaje" class="mb-1 block text-sm font-medium text-marca-tinta">Mensaje</label>
    <textarea
      id="mensaje"
      name="mensaje"
      rows="5"
      required
      class="w-full rounded-md border border-marca-borde px-4 py-2.5 focus:border-marca-acento focus:outline-none"
    ></textarea>
  </div>

  <div class="flex flex-wrap gap-3">
    <button type="submit" class="btn-primario">Enviar por correo</button>
    <button type="button" id="btn-wa" class="btn-primario whitespace-nowrap !bg-[#25D366] hover:!bg-[#1da851]">
      <IconoWA size={18} />
      Enviar por WhatsApp
    </button>
  </div>

  <p class="text-sm text-marca-secundario">
    Con <strong>"Enviar por correo"</strong> se abrira su programa de correo con el mensaje
    listo para <strong>{site.email}</strong>. Con <strong>"Enviar por WhatsApp"</strong> se
    abrira un chat con el mensaje prellenado.
  </p>
</form>

<script>
  // Envio sin servidor: por correo (mailto) o por WhatsApp (wa.me).
  const form = document.getElementById('form-contacto') as HTMLFormElement | null;
  const destino = form?.dataset.email ?? '';
  const waBase = form?.dataset.wa ?? '';

  const get = (k: string) => String(new FormData(form!).get(k) ?? '');
  const lineas = () =>
    [
      `Nombre: ${get('nombre')}`,
      `Empresa: ${get('empresa')}`,
      `Correo: ${get('correo')}`,
      `Telefono: ${get('telefono')}`,
      '',
      'Mensaje:',
      get('mensaje'),
    ].join('\n');

  // Por correo (submit del formulario).
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    const asunto = `Consulta web de ${get('nombre')}`;
    window.location.href = `mailto:${destino}?subject=${encodeURIComponent(asunto)}&body=${encodeURIComponent(lineas())}`;
  });

  // Por WhatsApp (boton dedicado).
  document.getElementById('btn-wa')?.addEventListener('click', () => {
    if (!form?.reportValidity()) return;
    const texto = `Consulta web\n\n${lineas()}`;
    const sep = waBase.includes('?') ? '&' : '?';
    window.open(`${waBase}${sep}text=${encodeURIComponent(texto)}`, '_blank', 'noopener');
  });
</script>
