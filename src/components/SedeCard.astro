---
/* ==========================================================================
   SEDE CARD — Tarjeta de sede (Arequipa)
   ========================================================================== */
import type { Sede } from '../config/site';
interface Props {
  sede: Sede;
}
const { sede } = Astro.props;
---

<article class="rounded-lg border border-marca-borde bg-white p-8">
  <div class="flex items-center gap-3">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2b6cb0" stroke-width="2" aria-hidden="true">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"></path>
      <circle cx="12" cy="10" r="3"></circle>
    </svg>
    <h3 class="text-xl font-bold">Sede {sede.ciudad}</h3>
  </div>
  <p class="mt-3 leading-relaxed text-marca-secundario">{sede.direccion}</p>
</article>
