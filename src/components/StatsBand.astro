---
/* ==========================================================================
   STATS BAND — Franja de cifras / credibilidad (fondo azul de marca)
   Recibe { valor, etiqueta, icono? } y los muestra en columnas con icono.
   ========================================================================== */
import { Icon } from 'astro-icon/components';

interface Cifra {
  valor: string;
  etiqueta: string;
  /** Nombre de icono mdi (opcional), p. ej. "mdi:clock-outline" */
  icono?: string;
}
interface Props {
  cifras: Cifra[];
}
const { cifras } = Astro.props;
---

<section class="bg-marca-primario">
  <dl class="contenedor grid grid-cols-2 gap-y-8 py-8 md:grid-cols-4 md:py-10">
    {
      cifras.map((cifra, i) => (
        <div
          class="flex flex-col items-center px-4 text-center md:border-marca-primario-claro"
          class:list={[i % 2 === 1 && 'border-l md:border-l', i >= 2 && 'md:border-l']}
          data-reveal
          style={`--reveal-delay:${i * 90}ms`}
        >
          {cifra.icono && (
            <Icon name={cifra.icono} class="mb-2 h-8 w-8 text-marca-resalte" />
          )}
          <dt class="font-display text-4xl text-white md:text-5xl" data-contador>{cifra.valor}</dt>
          <dd class="mt-1 text-xs font-semibold uppercase tracking-wider text-white/70 md:text-sm">
            {cifra.etiqueta}
          </dd>
        </div>
      ))
    }
  </dl>
</section>

<script>
  // Anima (cuenta ascendente) los valores puramente numericos al entrar en pantalla.
  // Los valores con simbolos (24/7, 3D) se muestran tal cual.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const contadores = document.querySelectorAll<HTMLElement>('[data-contador]');

  const animar = (el: HTMLElement) => {
    const texto = (el.textContent ?? '').trim();
    const m = texto.match(/^(\+)?(\d+)$/);
    if (!m) return; // solo numeros puros (opcional prefijo +)
    const prefijo = m[1] ?? '';
    const fin = parseInt(m[2], 10);
    const duracion = 1300;
    let inicio = 0;
    const paso = (t: number) => {
      if (!inicio) inicio = t;
      const p = Math.min(1, (t - inicio) / duracion);
      const val = Math.round((1 - Math.pow(1 - p, 3)) * fin); // easeOutCubic
      el.textContent = prefijo + val;
      if (p < 1) requestAnimationFrame(paso);
    };
    requestAnimationFrame(paso);
  };

  if (reduce || !('IntersectionObserver' in window)) {
    // sin animacion: se quedan con su valor final (ya renderizado)
  } else {
    const io = new IntersectionObserver(
      (entradas) => {
        entradas.forEach((e) => {
          if (e.isIntersecting) {
            io.unobserve(e.target);
            animar(e.target as HTMLElement);
          }
        });
      },
      { threshold: 0.5 }
    );
    contadores.forEach((el) => io.observe(el));
  }
</script>
