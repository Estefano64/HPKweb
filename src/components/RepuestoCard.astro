---
/* ==========================================================================
   REPUESTO CARD — Tarjeta de categoria de repuestos (estilo brochure)
   Medallon circular con arco turquesa, panel azul con el titulo, lista de
   items y boton "Pedir por WhatsApp" con el pedido prellenado.
   ========================================================================== */
import { Image } from 'astro:assets';
import type { CategoriaRepuesto } from '../config/site';
import { site, waHref } from '../config/site';
import { imagenRepuesto } from '../lib/imagenes';
import IconoWA from './IconoWA.astro';

interface Props {
  categoria: CategoriaRepuesto;
}
const { categoria } = Astro.props;

const imagen = imagenRepuesto(categoria.id);
const mensaje = `Hola ${site.nombreCorto}, quisiera cotizar repuestos de la línea "${categoria.titulo}". Detalle: `;
---

<article class="flex h-full flex-col rounded-xl border border-marca-borde bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  {/* Medallon circular con arco turquesa */}
  <div class="relative mx-auto aspect-square w-36 sm:w-40">
    <div class="absolute -inset-2 -rotate-45 rounded-full border-[9px] border-marca-acento border-r-transparent border-t-transparent" aria-hidden="true"></div>
    <Image
      src={imagen}
      alt={`Repuestos: ${categoria.titulo}`}
      class="absolute inset-0 h-full w-full rounded-full border-4 border-white bg-marca-primario object-cover shadow-md"
      width={400}
      height={400}
      loading="lazy"
    />
  </div>

  {/* Panel azul con titulo */}
  <div class="mt-5 rounded-lg rounded-tr-2xl bg-marca-primario px-4 py-2.5 text-center">
    <h3 class="text-lg text-white md:text-xl">{categoria.titulo}</h3>
  </div>

  <ul class="mt-4 flex-1 space-y-2">
    {
      categoria.items.map((item) => (
        <li class="flex items-start gap-2.5 text-sm text-marca-secundario">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-marca-acento" aria-hidden="true"></span>
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <a
    href={waHref(mensaje)}
    target="_blank"
    rel="noopener"
    class="btn-primario mt-6 w-full justify-center whitespace-nowrap !bg-[#25D366] hover:!bg-[#1da851]"
  >
    <IconoWA size={18} />
    Pedir por WhatsApp
  </a>
</article>
