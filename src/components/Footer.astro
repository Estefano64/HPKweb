---
/* ==========================================================================
   FOOTER — Pie de pagina (reutilizable)
   Muestra contacto, sedes y navegación. Lee todo desde site.ts.
   ========================================================================== */
import { site, telHref, waHref } from '../config/site';
import IconoWA from './IconoWA.astro';

const anio = new Date().getFullYear();

// Redes con URL definida (las vacias no se muestran).
const redes = (
  [
    { nombre: 'Facebook', url: site.redes.facebook },
    { nombre: 'Instagram', url: site.redes.instagram },
    { nombre: 'LinkedIn', url: site.redes.linkedin },
  ] as const
).filter((r) => r.url);
---

<footer class="border-t border-marca-borde bg-marca-primario text-white">
  <div class="contenedor grid gap-10 py-14 md:grid-cols-3">
    {/* Columna 1: identidad */}
    <div>
      <p class="font-display text-lg font-bold">{site.nombre}</p>
      <p class="mt-1 text-xs text-white/50">RUC {site.empresa.ruc}</p>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-white/70">
        {site.lema}.
      </p>
    </div>

    {/* Columna 2: contacto */}
    <div>
      <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-white/90">Contacto</h2>
      <ul class="mt-4 space-y-2 text-sm text-white/80">
        <li>
          <a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a>
        </li>
        {
          site.telefonos.map((tel) => (
            <li>
              <a href={`tel:${telHref(tel)}`} class="hover:text-white">
                {tel}
              </a>
            </li>
          ))
        }
        <li>
          <a href={waHref(`Hola ${site.nombreCorto}, quisiera más información.`)} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 font-semibold text-white hover:text-white/80">
            <IconoWA size={15} />
            WhatsApp {site.whatsapp}
          </a>
        </li>
      </ul>

      {
        redes.length > 0 && (
          <ul class="mt-4 flex gap-4 text-sm">
            {redes.map((r) => (
              <li>
                <a href={r.url} target="_blank" rel="noopener" class="text-white/70 hover:text-white">
                  {r.nombre}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    {/* Columna 3: sede + mapa incrustado */}
    <div>
      <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-white/90">Sede</h2>
      <ul class="mt-4 space-y-3 text-sm text-white/80">
        {
          site.sedes.map((sede) => (
            <li>
              <span class="font-semibold text-white">{sede.ciudad}</span>
              <br />
              {sede.direccion}
            </li>
          ))
        }
      </ul>
      {
        site.sedes[0]?.mapaEmbed && (
          <iframe
            src={site.sedes[0].mapaEmbed}
            title={`Ubicación de ${site.nombreCorto} en Google Maps`}
            class="mt-4 h-44 w-full rounded-lg border border-white/10"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        )
      }
    </div>
  </div>

  {/* Barra inferior */}
  <div class="border-t border-white/10">
    <div class="contenedor flex flex-col items-center justify-between gap-3 py-5 text-xs text-white/60 sm:flex-row">
      <p>&copy; {anio} {site.nombre}. Todos los derechos reservados.</p>
      <nav aria-label="Navegación del pie">
        <ul class="flex flex-wrap gap-x-5 gap-y-1">
          {
            site.nav.map((enlace) => (
              <li>
                <a href={enlace.href} class="hover:text-white">
                  {enlace.texto}
                </a>
              </li>
            ))
          }
          <li>
            <a href="/faq/" class="hover:text-white">Preguntas frecuentes</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
