---
/* ==========================================================================
   VIDEO EMPRESA — Reproductor de YouTube con carga diferida ("facade")
   Muestra la miniatura local + boton de play. Solo al hacer clic se carga el
   iframe de YouTube (dominio nocookie), evitando peticiones y cookies de
   terceros en la carga inicial (mejor rendimiento y privacidad).
   ========================================================================== */
import { Image } from 'astro:assets';
import poster from '../assets/video-empresa.jpg';

interface Props {
  /** ID del video de YouTube (la parte despues de v=) */
  videoId: string;
  /** Titulo accesible del video */
  titulo?: string;
}
const { videoId, titulo = 'Video de presentacion' } = Astro.props;
---

<div
  class="lite-yt group relative aspect-video w-full cursor-pointer overflow-hidden rounded-2xl bg-marca-primario shadow-lg ring-1 ring-marca-borde"
  data-id={videoId}
  data-titulo={titulo}
>
  <Image
    src={poster}
    alt={titulo}
    class="absolute inset-0 h-full w-full object-cover"
    loading="lazy"
    width={1280}
    height={720}
  />
  <button
    type="button"
    class="lite-yt__btn absolute inset-0 flex items-center justify-center bg-marca-primario/25 transition-colors group-hover:bg-marca-primario/10"
    aria-label={`Reproducir video: ${titulo}`}
  >
    <span
      class="flex h-16 w-16 items-center justify-center rounded-full bg-white/95 shadow-xl transition-transform group-hover:scale-110 md:h-20 md:w-20"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" class="ml-1 h-7 w-7 text-marca-primario md:h-8 md:w-8" aria-hidden="true">
        <path d="M8 5v14l11-7z" />
      </svg>
    </span>
  </button>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.lite-yt').forEach((caja) => {
    const id = caja.dataset.id;
    const titulo = caja.dataset.titulo ?? 'Video';
    caja.querySelector('.lite-yt__btn')?.addEventListener('click', () => {
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = titulo;
      iframe.className = 'absolute inset-0 h-full w-full';
      iframe.setAttribute('allow', 'autoplay; encrypted-media; picture-in-picture; fullscreen');
      iframe.setAttribute('allowfullscreen', 'true');
      iframe.setAttribute('loading', 'lazy');
      caja.innerHTML = '';
      caja.classList.remove('cursor-pointer', 'group');
      caja.appendChild(iframe);
    });
  });
</script>
