---
/* ==========================================================================
   CARRUSEL FOTOS — Fila con scroll lateral + lightbox (clic para ampliar)
   Recibe `fotos` = [{ src: ImageMetadata, alt: string }]. JS mínimo, sin deps.
   ========================================================================== */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  fotos: { src: ImageMetadata; alt: string }[];
}
const { fotos } = Astro.props;
---

<div class="cf">
  <div class="flex snap-x gap-4 overflow-x-auto pb-4 [scrollbar-color:var(--color-marca-acento)_transparent] [scrollbar-width:thin]">
    {
      fotos.map((foto, i) => (
        <button
          type="button"
          class="group relative aspect-[4/3] w-72 shrink-0 snap-start overflow-hidden rounded-xl border border-marca-borde bg-marca-niebla shadow-sm sm:w-80"
          data-cf-abrir
          data-i={i}
          aria-label={`Ampliar foto: ${foto.alt}`}
        >
          <Image
            src={foto.src}
            alt={foto.alt}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            width={800}
            height={600}
            loading="lazy"
          />
          <span class="pointer-events-none absolute bottom-2 right-2 flex h-8 w-8 items-center justify-center rounded-full bg-black/40 text-white opacity-0 transition-opacity group-hover:opacity-100">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4" aria-hidden="true">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
            </svg>
          </span>
        </button>
      ))
    }
  </div>

  {/* Lightbox */}
  <div
    class="cf-lightbox fixed inset-0 z-[60] hidden items-center justify-center bg-black/85 p-4"
    role="dialog"
    aria-modal="true"
    aria-label="Foto ampliada"
  >
    <button type="button" class="cf-cerrar absolute right-4 top-4 rounded-full bg-white/10 p-2 text-white transition-colors hover:bg-white/20" aria-label="Cerrar">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
    </button>
    <button type="button" class="cf-prev absolute left-2 top-1/2 -translate-y-1/2 rounded-full bg-white/10 p-3 text-white transition-colors hover:bg-white/20 md:left-6" aria-label="Foto anterior">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="15 18 9 12 15 6" /></svg>
    </button>
    <figure class="max-h-[88vh] max-w-5xl text-center">
      <img class="cf-img mx-auto max-h-[80vh] w-auto rounded-lg" src="" alt="" />
      <figcaption class="cf-cap mt-3 text-sm text-white/80"></figcaption>
    </figure>
    <button type="button" class="cf-next absolute right-2 top-1/2 -translate-y-1/2 rounded-full bg-white/10 p-3 text-white transition-colors hover:bg-white/20 md:right-6" aria-label="Foto siguiente">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6" /></svg>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.cf').forEach((raiz) => {
    const botones = Array.from(raiz.querySelectorAll<HTMLButtonElement>('[data-cf-abrir]'));
    const fotos = botones.map((b) => {
      const img = b.querySelector('img');
      return { src: img?.currentSrc || img?.src || '', alt: img?.alt || '' };
    });
    const lightbox = raiz.querySelector<HTMLElement>('.cf-lightbox');
    const imgGrande = raiz.querySelector<HTMLImageElement>('.cf-img');
    const cap = raiz.querySelector<HTMLElement>('.cf-cap');
    let actual = 0;

    const mostrar = (i: number) => {
      if (!fotos.length || !imgGrande) return;
      actual = (i + fotos.length) % fotos.length;
      imgGrande.src = fotos[actual].src;
      imgGrande.alt = fotos[actual].alt;
      if (cap) cap.textContent = fotos[actual].alt;
    };
    const abrir = (i: number) => {
      mostrar(i);
      lightbox?.classList.remove('hidden');
      lightbox?.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };
    const cerrar = () => {
      lightbox?.classList.add('hidden');
      lightbox?.classList.remove('flex');
      document.body.style.overflow = '';
    };

    botones.forEach((b, i) => b.addEventListener('click', () => abrir(i)));
    raiz.querySelector('.cf-cerrar')?.addEventListener('click', cerrar);
    raiz.querySelector('.cf-prev')?.addEventListener('click', () => mostrar(actual - 1));
    raiz.querySelector('.cf-next')?.addEventListener('click', () => mostrar(actual + 1));
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) cerrar();
    });
    document.addEventListener('keydown', (e) => {
      if (!lightbox || lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') cerrar();
      if (e.key === 'ArrowLeft') mostrar(actual - 1);
      if (e.key === 'ArrowRight') mostrar(actual + 1);
    });
  });
</script>
